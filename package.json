{
  "name": "n8n-nodes-realtyapi",
  "version": "0.1.0",
  "description": "n8n community node for RealtyAPI — call any of 33 real-estate providers (Zillow, Redfin, Realtor, Zoopla, Rightmove, Bayut, and more) and 400+ endpoints from your workflows.",
  "keywords": [
    "n8n-community-node-package",
    "realtyapi",
    "real-estate",
    "zillow",
    "redfin",
    "realtor",
    "property",
    "n8n"
  ],
  "license": "MIT",
  "homepage": "https://realtyapi.io",
  "author": {
    "name": "RealtyAPI",
    "email": "support@realtyapi.io"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/realtyapi/n8n-nodes-realtyapi.git"
  },
  "engines": {
    "node": ">=20.15"
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/RealtyApiApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/RealtyApi/RealtyApi.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.32.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^5.0.0",
    "n8n-workflow": "*",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  }
}
